{
  "hosting": {
    "public": ".next",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "DatabaseAdmin/**"
    ],
    "rewrites": [
      {
        "source": "/vault/**",
        "destination": "/index.html"
      },
      {
        "source": "/dashboard",
        "destination": "/index.html"
      },
      {
        "source": "/onboarding",
        "destination": "/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "vapi-key.txt",
        ".runtimeconfig.json",
        "**/*.test.js",
        "**/node_modules/**"
      ]
    }
  ],
  "targets": {
    "listtobid-9ede2": {
      "firestore": {
        "rules": [
          "firestore"
        ]
      }
    }
  },
  "emulators": {
    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  }
}
